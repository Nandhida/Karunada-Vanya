<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2D6A4F"
        android:gravity="center_vertical"
        android:paddingStart="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊 Forest Sounds"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a card to hear Karnataka's wildlife"
        android:textSize="13sp"
        android:textColor="#52796F"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Elephant -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardElephant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#E8F5E9">
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="🐘"
                        android:textSize="30sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Indian Elephant"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1B4332"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trumpeting call"
                            android:textSize="13sp"
                            android:textColor="#52796F"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnElephant"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="#2D6A4F"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tiger -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardTiger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#FFF3E0">
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="🐯"
                        android:textSize="30sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bengal Tiger"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1B4332"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Roar in the wild"
                            android:textSize="13sp"
                            android:textColor="#52796F"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnTiger"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="#2D6A4F"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Peacock -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardPeacock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#E3F2FD">
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="🦚"
                        android:textSize="30sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Indian Peacock"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1B4332"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monsoon dance call"
                            android:textSize="13sp"
                            android:textColor="#52796F"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnPeacock"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="#2D6A4F"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hornbill -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardHornbill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#F3E5F5">
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="🦜"
                        android:textSize="30sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Great Hornbill"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1B4332"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Karnataka's state bird"
                            android:textSize="13sp"
                            android:textColor="#52796F"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnHornbill"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="#2D6A4F"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Jungle Ambience -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardJungle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#E8F5E9">
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="🌿"
                        android:textSize="30sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forest Ambience"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1B4332"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Karnataka jungle sounds"
                            android:textSize="13sp"
                            android:textColor="#52796F"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnJungle"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:background="#2D6A4F"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>