<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2D6A4F"
        android:gravity="center_vertical"
        android:paddingStart="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 Movement Alert"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report a Sighting"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B4332"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Animal"
                android:textSize="13sp"
                android:textColor="#52796F"/>

            <Spinner
                android:id="@+id/spinnerAnimal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#E8F5E9"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Village / Location"
                android:textSize="13sp"
                android:textColor="#52796F"/>

            <EditText
                android:id="@+id/editLocation"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g. Nagarhole village"
                android:background="#E8F5E9"
                android:paddingStart="10dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnSendAlert"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🚨 Send Community Alert"
                android:backgroundTint="#D62828"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Alerts (last 6 hours)"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1B4332"
        android:paddingStart="16dp"
        android:paddingBottom="6dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/alertRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>